№╗┐<Window x:Class="AssignmentRecordationHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AssignmentRecordationHelper"
        Title="Assignment Recordation Helper"
        MinWidth="820" MinHeight="500"
        Width="1040" Height="720"
        Background="#F5F7FA">

  <Window.Resources>
    <!-- Severity ├бРђаРђЎ background color for Comments cell -->
    <local:SeverityToBrushConverter x:Key="SeverityToBrush"/>
    <!-- Bool ├бРђаРђЎ Visibility (true = Visible) -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <!-- Bool ├бРђаРђЎ Visibility (true = Collapsed) -->
    <local:InvertBoolToVisibilityConverter x:Key="InvertBoolToVis"/>
    <!-- Bool ├бРђаРђЎ FontStyle (true = Italic) -->
    <local:BoolToFontStyleConverter x:Key="BoolToItalic"/>
    <!-- Bool ├бРђаРђЎ Foreground (true = grey hint) -->
    <local:BoolToHintBrushConverter x:Key="BoolToHintBrush"/>
    <!-- Mismatch string ├бРђаРђЎ foreground color -->
    <local:MismatchTextConverter x:Key="MismatchText"/>

    <Style x:Key="PickerBox" TargetType="Border">
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="#C8D6E5"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="PickerBoxSelected" TargetType="Border">
      <Setter Property="Background" Value="#EBF3FB"/>
      <Setter Property="BorderBrush" Value="#003366"/>
      <Setter Property="BorderThickness" Value="1.5"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="Cursor" Value="Arrow"/>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="#003366"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="24,8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="5" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#004488"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#A0AAB8"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="CopyButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="2,0"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="#003366"/>
      <Setter Property="ToolTip" Value="Click to copy"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E0ECF8"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SectionHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#003366"/>
      <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#003366"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="8,6"/>
      <Setter Property="BorderThickness" Value="0,0,1,0"/>
      <Setter Property="BorderBrush" Value="#336699"/>
    </Style>
  </Window.Resources>

  <Grid Margin="16" x:Name="RootGrid"
        AllowDrop="True"
        DragEnter="Window_DragEnter" DragOver="Window_DragOver"
        DragLeave="Window_DragLeave" Drop="Window_Drop">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Title -->
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>  <!-- File pickers -->
      <RowDefinition Height="10"/>
      <RowDefinition Height="Auto"/>  <!-- Status + Process -->
      <RowDefinition Height="12"/>
      <RowDefinition Height="*"/>     <!-- Results -->
    </Grid.RowDefinitions>

    <!-- A transparent background so drag events fire over empty areas of the window -->
    <Grid.Background>
      <SolidColorBrush Color="#F5F7FA"/>
    </Grid.Background>

    <!-- ├бРђЮРѓг├бРђЮРѓг Title ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг -->
    <StackPanel Grid.Row="0" Orientation="Horizontal">
      <TextBlock Text="Assignment Recordation Prep"
                 FontSize="20" FontWeight="Bold" Foreground="#003366"/>
      <TextBlock Text=" ├бРѓгРђЮ drag the assignments and ADS anywhere onto this window"
                 FontSize="13" Foreground="#666" VerticalAlignment="Bottom" Margin="4,0,0,2"/>
    </StackPanel>

    <!-- ├бРђЮРѓг├бРђЮРѓг File pickers ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг -->
    <UniformGrid Grid.Row="2" Columns="2" x:Name="FilePickerPanel">

      <!-- Assignments slot -->
      <Border x:Name="AssignBorder" Style="{StaticResource PickerBox}"
              MouseLeftButtonDown="AssignSlot_Click"
              Margin="0,0,6,0">
        <StackPanel>
          <TextBlock Text="ASSIGNMENTS" FontSize="11" FontWeight="SemiBold"
                     Foreground="#888" Margin="0,0,0,3"/>
          <TextBlock x:Name="AssignLabel"
                     Text="Click to select the executed assignments ├бРѓгРђЮ a combined PDF, a folder, or several PDFs"
                     TextWrapping="Wrap" FontSize="12" Foreground="#555"/>
        </StackPanel>
      </Border>

      <!-- ADS slot -->
      <Border x:Name="AdsBorder" Style="{StaticResource PickerBox}"
              MouseLeftButtonDown="AdsSlot_Click"
              Margin="6,0,0,0">
        <StackPanel>
          <TextBlock Text="ADS" FontSize="11" FontWeight="SemiBold"
                     Foreground="#888" Margin="0,0,0,3"/>
          <TextBlock x:Name="AdsLabel"
                     Text="Click to select the ADS (PTO/AIA/14) PDF"
                     TextWrapping="Wrap" FontSize="12" Foreground="#555"/>
        </StackPanel>
      </Border>
    </UniformGrid>

    <!-- ├бРђЮРѓг├бРђЮРѓг Status + Process button ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг -->
    <Grid Grid.Row="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <TextBlock x:Name="StatusText"
                 VerticalAlignment="Center"
                 FontSize="12" Foreground="#444"
                 TextWrapping="Wrap"/>

      <Button x:Name="ProcessButton" Grid.Column="1"
              Content="Process" Style="{StaticResource PrimaryButton}"
              IsEnabled="False" Click="Process_Click"
              Margin="12,0,0,0"/>
    </Grid>

    <!-- ├бРђЮРѓг├бРђЮРѓг Results ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг -->
    <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto">
      <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">

        <!-- Four-column assignment table -->
        <TextBlock Style="{StaticResource SectionHeader}"
                   Text="ASSIGNMENT CENTER ├бРѓгРђЮ CONVEYING PARTIES"
                   Margin="0,0,0,4"/>
        <TextBlock FontSize="11" Foreground="#666" Margin="0,0,0,8"
                   Text="Click a name or date cell to copy it."/>

        <DataGrid x:Name="ResultsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectionUnit="Cell"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E0E8F0"
                  RowBackground="White"
                  AlternatingRowBackground="#F8FAFC"
                  BorderBrush="#C8D6E5" BorderThickness="1"
                  ColumnHeaderStyle="{StaticResource GridHeader}"
                  HeadersVisibility="Column"
                  RowHeight="64">

          <DataGrid.Columns>

            <!-- Name column -->
            <DataGridTemplateColumn Header="Name" Width="210" IsReadOnly="True">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Button Style="{StaticResource CopyButton}"
                          Tag="{Binding Name}"
                          Click="CopyCell_Click"
                          HorizontalContentAlignment="Left"
                          VerticalContentAlignment="Center"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Padding="6,4">
                    <TextBlock Text="{Binding Name}"
                               TextWrapping="Wrap" FontSize="12"/>
                  </Button>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Signature Date column (editable + copy) -->
            <DataGridTemplateColumn Header="Signature Date (MM/DD/YYYY)" Width="170" IsReadOnly="False">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBox Text="{Binding SignatureDate, UpdateSourceTrigger=PropertyChanged}"
                           FontStyle="{Binding IsHint, Converter={StaticResource BoolToItalic}}"
                           Foreground="{Binding IsHint, Converter={StaticResource BoolToHintBrush}}"
                           FontSize="12"
                           BorderThickness="0" Background="Transparent"
                           VerticalAlignment="Center" Padding="6,0,6,0"
                           PreviewMouseLeftButtonDown="DateBox_Click"
                           ToolTip="{Binding DateToolTip}"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Date Image column -->
            <DataGridTemplateColumn Header="Date Image" Width="165" IsReadOnly="True">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="├бРѓгРђЮ" FontSize="12" Foreground="#AAA"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasDateImage, Converter={StaticResource InvertBoolToVis}}"/>
                    <Border Visibility="{Binding HasDateImage, Converter={StaticResource BoolToVis}}"
                            BorderBrush="#C8D6E5" BorderThickness="1" Cursor="Hand"
                            MouseLeftButtonDown="DateImage_Enlarge">
                      <Image Source="{Binding DateImage}" MaxHeight="55" MaxWidth="150"
                             Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                  </Grid>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <!-- Comments column -->
            <DataGridTemplateColumn Header="Comments" Width="*" IsReadOnly="True">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Border Background="{Binding Severity, Converter={StaticResource SeverityToBrush}}"
                          Padding="6,4">
                    <TextBlock Text="{Binding Comments}"
                               TextWrapping="Wrap" FontSize="11"
                               VerticalAlignment="Center"/>
                  </Border>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

          </DataGrid.Columns>
        </DataGrid>

        <!-- ADS Comparison section -->
        <Border Margin="0,16,0,0" BorderBrush="#C8D6E5" BorderThickness="1"
                CornerRadius="5" Background="White" Padding="12,10">
          <StackPanel>
            <TextBlock Style="{StaticResource SectionHeader}" Text="ADS COMPARISON"/>
            <ItemsControl x:Name="AdsMismatchList">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" Margin="0,2" FontSize="12"
                             Foreground="{Binding Converter={StaticResource MismatchText}}"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <TextBlock Height="20"/>
      </StackPanel>
    </ScrollViewer>

    <!-- Drag-over drop overlay (whole window) -->
    <Border x:Name="DropOverlay" Grid.RowSpan="7" Visibility="Collapsed"
            IsHitTestVisible="False"
            Background="#CC003366" BorderBrush="#FFFFFF" BorderThickness="3"
            CornerRadius="10" Margin="-16">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="├б┬цРђю" FontSize="64" Foreground="White"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Drop the assignments and ADS here"
                   FontSize="22" FontWeight="SemiBold" Foreground="White"
                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
        <TextBlock Text="They'll be sorted automatically by type"
                   FontSize="13" Foreground="#CFE0F0"
                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
      </StackPanel>
    </Border>

    <!-- Image enlargement overlay -->
    <Grid x:Name="ImageOverlay" Grid.RowSpan="7" Visibility="Collapsed"
          Background="#88000000" Cursor="Hand"
          MouseLeftButtonDown="ImageOverlay_Close">
      <Border Background="White" CornerRadius="8" Padding="12"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              MaxWidth="700" MaxHeight="500">
        <StackPanel>
          <Image x:Name="OverlayImage" MaxWidth="660" MaxHeight="420"
                 Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
          <TextBlock Text="Click anywhere to close" Margin="0,8,0,0"
                     HorizontalAlignment="Center" FontSize="11" Foreground="#888"/>
        </StackPanel>
      </Border>
    </Grid>

  </Grid>
</Window>
